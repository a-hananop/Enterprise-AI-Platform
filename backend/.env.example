# ============================================================
# Enterprise AI Decision Intelligence Platform - Environment
# ============================================================

# App Settings
APP_NAME="Enterprise AI Decision Intelligence Platform"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./data/enterprise_ai.db

# -------------------------------------------------------
# FREE AI APIs - Sign up for free tiers
# -------------------------------------------------------

# Groq API (FREE - https://console.groq.com)
# Free tier: 14,400 req/day, fast inference
GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini (FREE - https://aistudio.google.com)
# Alternative LLM - Free tier available
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace (FREE - https://huggingface.co)
# For downloading free models
HF_TOKEN=your_huggingface_token_here

# -------------------------------------------------------
# Vector Database (ChromaDB - FREE LOCAL)
# -------------------------------------------------------
CHROMA_PERSIST_DIR=./data/vectors
CHROMA_COLLECTION_NAME=enterprise_docs

# Embedding Model (FREE - runs locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# -------------------------------------------------------
# NLP Models (FREE - HuggingFace, run locally)
# -------------------------------------------------------
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
NER_MODEL=dslim/bert-base-NER
SUMMARIZATION_MODEL=facebook/bart-large-cnn
CLASSIFICATION_MODEL=facebook/bart-large-mnli

# -------------------------------------------------------
# File Storage
# -------------------------------------------------------
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=csv,xlsx,json,pdf,docx,txt,mp3,wav,mp4

# -------------------------------------------------------
# Redis (Optional - for task queue)
# -------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -------------------------------------------------------
# CORS
# -------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
